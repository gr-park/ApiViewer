{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/auto-zip-after-push.sh",
            "timeout": 60,
            "statusMessage": "git push 후 자동 압축..."
          }
        ]
      }
    ]
  }
}
